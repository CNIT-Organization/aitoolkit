# aitoolkit configuration. Copy to .env and adjust.
# All variables are prefixed AITOOLKIT_. Every value has a localhost default;
# set these to your own endpoints and model ids. The values below are
# placeholders — replace them with your deployment's hosts and models.

# --- LLM (vLLM or any OpenAI-compatible server) ---
AITOOLKIT_LLM_BASE_URL=http://localhost:8000/v1
AITOOLKIT_LLM_API_KEY=no-auth
AITOOLKIT_LLM_MODEL=your-llm-model
AITOOLKIT_LLM_TEMPERATURE=0.2

# --- Embeddings (any OpenAI-compatible embeddings server, e.g. TEI) ---
AITOOLKIT_EMBEDDINGS_BASE_URL=http://localhost:8001/v1
AITOOLKIT_EMBEDDINGS_API_KEY=no-auth
AITOOLKIT_EMBEDDINGS_MODEL=your-embedding-model
AITOOLKIT_EMBEDDINGS_BATCH_SIZE=32

# --- Speech-to-Text (any OpenAI-compatible transcription server) ---
AITOOLKIT_STT_BASE_URL=http://localhost:8003/v1
AITOOLKIT_STT_API_KEY=no-auth
AITOOLKIT_STT_MODEL=whisper-1
# AITOOLKIT_STT_LANGUAGE=en

# --- Text-to-Speech (custom /api/tts + /api/voices server) ---
AITOOLKIT_TTS_BASE_URL=http://localhost:8002
# AITOOLKIT_TTS_DEFAULT_VOICE=your-voice-id

# --- Vector store (Qdrant) ---
AITOOLKIT_QDRANT_URL=http://localhost:6333
AITOOLKIT_QDRANT_COLLECTION=documents
# AITOOLKIT_QDRANT_VECTOR_SIZE=  # leave unset to auto-detect from the embedding model
# Set to false if the server lags the client by >1 minor version (silences the warning).
# AITOOLKIT_QDRANT_CHECK_COMPATIBILITY=true

# --- Retriever cache (Redis, optional) ---
# AITOOLKIT_REDIS_URL=redis://localhost:6379/0
AITOOLKIT_CACHE_TTL=3600
